{
  "name": "@glassbox/server",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "node --watch dist/main.js",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@glassbox/adapter-claude": "workspace:*",
    "@glassbox/adapter-sdk": "workspace:*",
    "@glassbox/api-contract": "workspace:*",
    "@glassbox/domain": "workspace:*",
    "@glassbox/logging": "workspace:*"
  }
}
